# --- Database ---
DATABASE_URL=postgresql://gmb:gmb@localhost:5432/gmb_dev

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
TENANT_TOKEN_ENCRYPTION_KEY=change_me_32_byte_base64_key

# --- Queue (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Google Business Profile ---
# OAuth client used to connect a customer's Google Business account.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Places API key powering rank grid / leaderboard / battle map.
GOOGLE_PLACES_API_KEY=

# --- AI (optional: features degrade to templates without it) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Web ---
WEB_URL=http://localhost:3000
API_PORT=3001

# --- GMB tuning (optional) ---
# GMB_AUTO_SYNC_INTERVAL_MS=21600000
# GMB_AUTO_SYNC_LOCATION_SPACING_MS=2000
# GMB_BRANDED_IMAGE_INCLUDE_PHONE=false
