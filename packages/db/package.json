{
  "name": "@nexaflow/db",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "generate": "prisma generate --schema prisma/schema.prisma",
    "push": "prisma db push --schema prisma/schema.prisma",
    "validate": "prisma validate --schema prisma/schema.prisma",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.1.0"
  },
  "devDependencies": {
    "prisma": "^5.1.0"
  }
}
