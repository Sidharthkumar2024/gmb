{
  "name": "gmb",
  "private": true,
  "version": "0.1.0",
  "description": "Adgrowly GMB — standalone Google Business Profile / Local SEO platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:generate": "npm run generate --workspace=@nexaflow/db",
    "db:push": "npm run push --workspace=@nexaflow/db",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json",
    "test": "vitest run",
    "db:migrate": "npm run migrate --workspace=@nexaflow/db",
    "db:deploy": "npm run migrate:deploy --workspace=@nexaflow/db",
    "db:seed": "npm run seed --workspace=@nexaflow/db",
    "dev": "tsx watch apps/api/src/index.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "bcryptjs": "^3.0.3",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
